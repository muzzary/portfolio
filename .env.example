# EmailJS credentials for the Contact form (client-side).
# Create a free account at https://www.emailjs.com/, then copy this file to `.env`
# and fill in the values. All keys MUST keep the VITE_ prefix to be exposed to the app.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
